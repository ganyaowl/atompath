# This file is mounted into the Caddy container by docker-compose.yml.
# Change the site address if using another hostname. Its DNS A record must point
# to this server; add AAAA only when public IPv6 works.
atompath.ganyaowl.uz {
	encode zstd gzip
	reverse_proxy app:3000

	header {
		-Server
		X-Content-Type-Options nosniff
		Referrer-Policy strict-origin-when-cross-origin
	}
}
